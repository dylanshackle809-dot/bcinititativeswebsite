# Copy to .env.local for local dev (.env.local is gitignored via *.local).
# In production, set these in your hosting provider's env settings (Vercel:
# Project → Settings → Environment Variables).

# Required for the newsletter signup (src/lib/api/newsletter.functions.ts).
# Create one at https://resend.com/api-keys
RESEND_API_KEY=

# Optional. If set, contacts are added to this specific Resend audience
# (https://resend.com/audiences). If unset, they're created via the plain
# /contacts endpoint. Note: the `saved_opportunities` custom property may need
# to be created once in the Resend dashboard for it to be stored.
RESEND_AUDIENCE_ID=
